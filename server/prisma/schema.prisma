generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())

  interviews Interview[]
}

model Interview {
  id          Int      @id @default(autoincrement())
  title       String
  role        String
  difficulty  String

  questions   Json?

  answers     Answer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Answer {
  id          Int       @id @default(autoincrement())

  question    String
  answer      String

  score       Int?
  feedback    String?
  improvement String? 

  interviewId Int
  interview   Interview @relation(fields: [interviewId], references: [id])

  createdAt   DateTime @default(now())
}